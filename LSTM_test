import wfdb
import numpy as np
import matplotlib.pyplot as plt
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense
from sklearn.preprocessing import MinMaxScaler



#input data
data_path = r"D:\School\Research\Heart\bidmc-congestive-heart-failure-database-1.0.0"
profile_name = "chf01"
rec = wfdb.rdann(f"{data_path}/{profile_name}", "ecg")
interval = np.diff(rec.sample) / rec.fs

interval = interval[(interval > 0.3) & (interval < 2.0)]   #keep beat interval from 0.3-2seconds
keep = np.ones(len(interval), dtype=bool)
for i in range(1, len(interval)-1):
    if abs(interval[i] - interval[i-1]) > 0.5 or abs(interval[i] - interval[i+1]) > 0.5:       #clear jumps more than 0.5s
        keep[i] = False
clean_int = interval[keep]
final = clean_int[:3000]

scaler = MinMaxScaler()
scaled_data = scaler.fit_transform(final.reshape(-1, 1))         #normalizing the cleaned data

block = 20

def create_sequences(data, seq_len=block):
    feed =[]
    answer =[]
    for i in range(len(data) - seq_len):
        feed.append(data[i:i+seq_len])
        answer.append(data[i+seq_len])
    return np.array(feed), np.array(answer)          #feed first 20 data, give next as answer
feed, answer = create_sequences(scaled_data, block)

lstm = Sequential()                                # parameters of model
lstm.add(LSTM(50, input_shape=(block, 1)))
lstm.add(Dense(1))
lstm.compile(optimizer='adam', loss='mse')

lstm.fit(feed, answer, epochs=10, batch_size=32)             #training, 10 times
predict = lstm.predict(feed)
predict = scaler.inverse_transform(predict)               #convert back to seocnds
true_answer = scaler.inverse_transform(answer)

plt.figure(figsize=(12,5))
plt.plot(true_answer, label="Actual")
plt.plot(predict, label="Predicted")
plt.legend()
plt.show()